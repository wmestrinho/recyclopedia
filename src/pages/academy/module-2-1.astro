---
// Module 2.1 · The Circular Economy Dashboard — implementation of
// "Module 2.1.dc.html" (Claude Design project "Interactive School Modules",
// Track 2 plum accent). Knowledge check rendered by QuizLbga.svelte.
import LbgaModule from '../../layouts/LbgaModule.astro';
import LbgaBriefing from '../../components/LbgaBriefing.astro';
import LbgaFieldBrief from '../../components/LbgaFieldBrief.astro';
import QuizLbga from '../../components/QuizLbga.svelte';

const briefings = [
  {
    title: 'Briefing 1 · The three numbers',
    tag: 'the dashboard',
    body: `Whatever the city calls its report, three figures define the whole system. <strong>Diversion rate</strong> — the share of waste kept out of landfill by recycling, composting, and reuse. <strong>Tipping fee</strong> — the dollars-per-ton charged to dump. <strong>Cost per household</strong> — total program spend divided by served homes.`,
    callout: `<strong>Where to find them:</strong> the annual Municipal Solid Waste (MSW) report or Integrated Waste Management Plan — usually public, often buried on the city's public-works page.`,
  },
  {
    title: 'Briefing 2 · The landfill audit walk',
    tag: 'on-site',
    body: `Request a site visit and walk the operation. Note the <strong>active cell</strong> (where today's waste lands), the <strong>leachate collection</strong> system that catches toxic runoff, the <strong>gas capture or flare</strong> handling methane, the <strong>daily cover</strong> sealing each layer, and the <strong>scale-house records</strong> that log every inbound ton.`,
    callout: `<strong>What good looks like:</strong> gas is captured (not just flared), leachate is tested, and the scale house can hand you tonnage-by-stream on request.`,
  },
  {
    title: 'Briefing 3 · Benchmarking',
    tag: 'context',
    body: `A number means nothing alone. Compare your city's diversion rate to the <strong>~32% US national average</strong>, with strong programs clearing <strong>50%+</strong>. Then find the single biggest stream by weight — in most cities it is organics plus OCC (old corrugated cardboard). That is where the largest, cheapest gains hide.`,
    callout: `<strong>Operator's read:</strong> the biggest stream, not the loudest material, is where a diversion program earns its money back first.`,
  },
];
---

<LbgaModule
  title="Module 2.1 · The Circular Economy Dashboard"
  description="Read your city like a balance sheet. Pull the municipal waste budget, read the three numbers that matter — diversion rate, tipping fee, cost per household — and audit the landfill they pay for. Track 2: Professional Operations."
  trackLabel="Track 2: Professional Operations"
  badgeLabel="Module 2.1 · Certification"
  badgeDot="#8A2450"
  badgeColor="#E7A9C0"
  stripe="rgba(138,36,80,.13)"
  kicker="Module 2.1 · The Circular Economy Dashboard"
  kickerColor="#E7A9C0"
  heading="Read your city like a balance sheet"
  lede="Every municipality runs a waste budget whether it publishes one or not. The certified operator's first skill is to pull that budget, read the three numbers that actually matter, and audit the landfill those numbers pay for."
  pills={[
    { text: '3 briefings' },
    { text: '1 knowledge check' },
    { text: 'Certification tier', style: 'background:rgba(138,36,80,.28);border-color:rgba(138,36,80,.6);color:#F0C4D5' },
  ]}
  accent="#8A2450"
  storageKey="lbga_m2_1_done"
>
  {briefings.map((b, i) => (
    <LbgaBriefing title={b.title} tag={b.tag} body={b.body} callout={b.callout} last={i === briefings.length - 1} />
  ))}

  <section aria-label="Knowledge check">
    <div class="lm-check-kicker">Knowledge check · Circular Economy Dashboard</div>
    <div class="lm-quiz-frame">
      <QuizLbga client:visible quizId="academy_2_1_a" />
    </div>
  </section>

  <LbgaFieldBrief
    kicker="Field brief"
    kickerColor="#E7A9C0"
    title="Pull your city's numbers"
    body="Find your municipality's latest MSW report and record the three numbers — diversion rate, tipping fee, cost per household. Then compare all three against a neighboring town. The gaps you find are your first operator's memo."
    chips={['① Find the MSW report', '② Record the 3 numbers', '③ Benchmark a neighbor']}
    chipColor="#F0C4D5"
    chipBg="rgba(138,36,80,.22)"
    chipBorder="rgba(138,36,80,.5)"
  />
</LbgaModule>
