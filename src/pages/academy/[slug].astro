---
import { getCollection, render } from 'astro:content';
import LbgFooter from '../../components/LbgFooter.astro';
import LbgHeader from '../../components/LbgHeader.astro';
import Quiz from '../../components/Quiz.svelte';

export async function getStaticPaths() {
  const lessons = await getCollection('academy', ({ data }) => !data.draft);
  return lessons.map((lesson) => ({
    params: { slug: lesson.id },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const { Content } = await render(lesson);
---

<!DOCTYPE html>
<html lang={lesson.data.lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{lesson.data.title} | LBG Academy</title>
  <meta name="description" content={lesson.data.summary} />
  <link
    rel="canonical"
    href={`https://lettucebeetgrapefruit.org/academy/${lesson.id}`}
  />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/lbg-theme.css" />
</head>
<body class="lbg-site lbg-academy">
  <a class="skip-link" href="#lesson-top">Skip to content</a>
  <LbgHeader surface="academy" />

  <main class="site-shell">
    <article class="page is-active lesson" id="lesson-top">
      <p class="lesson__crumb">
        <a href="https://lettucebeetgrapefruit.org/#menu">← The Menu</a>
        · {lesson.data.track}
      </p>
      <p class="section-kicker">Course {lesson.data.module}</p>
      <h1 class="lesson__title">{lesson.data.title}</h1>
      <p class="lede" style="margin-bottom: 2rem;">{lesson.data.summary}</p>

      <div class="lesson__body">
        <Content />
      </div>

      {lesson.data.quizzes.length > 0 && (
        <section class="lesson__quizzes" aria-labelledby="taste-test-title">
          <div class="lbg-section__heading" style="margin-top: 3rem;">
            <p class="lbg-kicker">Taste Test</p>
            <h2 id="taste-test-title">Check what stayed with you.</h2>
            <p>Answer at your own pace. Every response includes the reason behind it.</p>
          </div>
          {lesson.data.quizzes.map((id) => (
            <Quiz client:visible quizId={id} />
          ))}
        </section>
      )}

      <p class="lesson__crumb lesson__crumb--end">
        <a href="https://lettucebeetgrapefruit.org/#menu">← Back to The Menu</a>
      </p>
    </article>
  </main>

  <LbgFooter surface="academy" />
</body>
</html>
