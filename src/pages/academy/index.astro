---
import LbgFooter from '../../components/LbgFooter.astro';
import LbgHeader from '../../components/LbgHeader.astro';

// Track 1 course catalog — the LBGA-designed module pages (src/pages/academy/
// module-*.astro), which supersede the markdown lessons in src/content/academy/
// (those routes stay live but are no longer listed here).
const modules = [
  {
    slug: 'module-1-1',
    module: '1.1',
    title: 'The Hidden History of Your Trash',
    summary: 'How we went from open pits to engineered landfills — and why a landfill is a tomb, not a compost heap.',
  },
  {
    slug: 'module-1-2',
    module: '1.2',
    title: 'The Smartphone Sorting Guide',
    summary: 'How to actually sort an item in your hand — resin codes, the local list, and the one rule that matters most.',
  },
  {
    slug: 'module-1-3',
    module: '1.3',
    title: 'Zero-Waste Micro-Habits',
    summary: 'Four 60-second home habits that quietly keep hundreds of pounds of trash out of the landfill over a lifetime.',
  },
  {
    slug: 'module-1-4',
    module: '1.4',
    title: 'The Upcycling Masterclass',
    summary: 'Three low-tech blueprints that turn discarded bottles, textiles, and peels into higher-value tools — no workshop required.',
  },
  {
    slug: 'module-1-5',
    module: '1.5',
    title: 'The Zero-Waste Shopping Matrix',
    summary: 'A four-tier mental filter you run on packaging in the aisle — stop the trash before you buy it.',
  },
  {
    slug: 'module-1-6',
    module: '1.6',
    title: 'The Circular Wardrobe',
    summary: 'Read one label and keep fibers in a loop of care, wear, and repair — your closet is a waste stream.',
  },
  {
    slug: 'module-5',
    module: '5',
    title: 'The Myth-Busting Check',
    summary: 'The Track 1 capstone — bust the three sticky myths behind most bad recycling habits.',
  },
];
const starter = modules[0];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LBG Academy — Everyone Is Welcome at the Table</title>
  <meta
    name="description"
    content="Lettuce Beet Grapefruit Academy is a free, open school for practical environmental learning, honest recycling education, and everyday zero-waste action."
  />
  <link rel="canonical" href="https://lettucebeetgrapefruit.org/" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/lbg-theme.css" />
</head>
<body class="lbg-site lbg-academy">
  <a class="skip-link" href="#academy-top">Skip to content</a>
  <LbgHeader surface="academy" />

  <main class="site-shell" id="academy-top">
    <section class="lbg-hero" aria-labelledby="academy-title">
      <div class="lbg-hero__copy">
        <p class="lbg-kicker">Lettuce Beet Grapefruit Academy</p>
        <h1 id="academy-title">Everyone is welcome at the table.</h1>
        <p class="lede">
          A free, open school for understanding what we own, where it goes, and how
          small informed choices keep useful materials in motion. No greenwashing.
          No guilt. Just clear lessons and practical action.
        </p>
        <div class="cta-row">
          <a class="button button--solid" href="#menu">Explore The Menu</a>
          <a class="button button--ghost" href={`/academy/${starter.slug}`}>
            Start the first course
          </a>
        </div>
      </div>
      <aside class="lbg-hero__aside">
        <div>
          <div class="lbg-trio" aria-hidden="true">
            <span class="lbg-dot lbg-dot--lettuce"></span>
            <span class="lbg-dot lbg-dot--beet"></span>
            <span class="lbg-dot lbg-dot--grapefruit"></span>
          </div>
          <h2 style="margin-top: 1.25rem;">Learn the why. Practice the how.</h2>
          <p>
            Courses draw from the same sourced research that powers Recyclopedia,
            presented here for learners of every age.
          </p>
        </div>
        <span class="lbg-status">Eight courses live</span>
      </aside>
    </section>

    <section class="lbg-section" id="menu" aria-labelledby="menu-title">
      <div class="lbg-section__heading">
        <p class="lbg-kicker">The Menu</p>
        <h2 id="menu-title">Choose what you are hungry to understand.</h2>
        <p>
          Start with a zero-prerequisite course, move through the core curriculum,
          and finish each lesson with an interactive Taste Test.
        </p>
      </div>

      <div class="lbg-band" style="margin-bottom: 1rem;">
        <div>
          <p class="lbg-kicker" style="color: #d9e8c5;">Starter</p>
          <h3>{starter.title}</h3>
          <p>{starter.summary}</p>
        </div>
        <a class="button button--ghost" href={`/academy/${starter.slug}`}>Begin here</a>
      </div>

      <p class="lbg-card__label" style="margin: 1.5rem 0 0.75rem;">Mains · Core curriculum</p>
      <div class="module-grid">
        {modules.map((m) => (
          <a class="module-card module-card--link" href={`/academy/${m.slug}`}>
            <p class="module-card__number">
              Course {m.module} · Citizen Science &amp; Action
            </p>
            <h3>{m.title}</h3>
            <p>{m.summary}</p>
            <p class="module-card__status module-card__status--live">
              Course live · Taste Test inside
            </p>
          </a>
        ))}
      </div>

      <p class="lbg-card__label" style="margin: 2rem 0 0.75rem;">
        Certification · Track 2: Professional Operations
      </p>
      <div class="module-grid">
        <a class="module-card module-card--link" href="/academy/module-2-1">
          <p class="module-card__number" style="color: var(--beet);">
            Module 2.1 · Certification tier
          </p>
          <h3>The Circular Economy Dashboard</h3>
          <p>
            Read your city like a balance sheet — pull the municipal waste budget,
            read the three numbers that matter, and audit the landfill they pay for.
          </p>
          <p class="module-card__status module-card__status--live">
            Course live · Knowledge check inside
          </p>
        </a>
      </div>
    </section>

    <section class="lbg-section" id="philosophy" aria-labelledby="philosophy-title">
      <div class="lbg-section__heading">
        <p class="lbg-kicker">Philosophy</p>
        <h2 id="philosophy-title">Gratitude before disposal.</h2>
        <p>
          The Gratitude Hierarchy asks for the highest respectful path that is
          actually available: reuse, repair, repurpose, donate, recycle, compost,
          and responsible disposal only as the last resort.
        </p>
      </div>
      <div class="lbg-card-grid">
        <article class="lbg-card">
          <span class="lbg-card__label">Principle one</span>
          <h3>Gratitude over guilt</h3>
          <p>We thank people for caring and give them a useful next action.</p>
        </article>
        <article class="lbg-card">
          <span class="lbg-card__label">Principle two</span>
          <h3>Never guess into a landfill</h3>
          <p>When evidence is incomplete, we say so and point to local truth.</p>
        </article>
        <article class="lbg-card">
          <span class="lbg-card__label">Principle three</span>
          <h3>Recycling is one rung</h3>
          <p>Keeping an object whole and useful usually beats breaking it down.</p>
        </article>
      </div>
    </section>

    <section class="lbg-section" id="library" aria-labelledby="library-title">
      <div class="lbg-section__heading">
        <p class="lbg-kicker">Research Library</p>
        <h2 id="library-title">One knowledge base, two surfaces.</h2>
        <p>
          LBGA teaches from the sourced environmental and material research behind
          the Recyclopedia engine. The public library will expand as reviewed
          papers and provenance records are cleared for release.
        </p>
      </div>
      <div class="lbg-empty-state">
        <h3>The shelves are being cataloged.</h3>
        <p>
          Course sources are already reviewed in-house. Public research volumes
          will appear here only after editorial and Creative Commons clearance.
        </p>
        <a class="button button--ghost" href="https://recyclopedia.cc">
          Open Recyclopedia
        </a>
      </div>
    </section>

    <section class="lbg-section" id="about" aria-labelledby="about-title">
      <div class="lbg-band">
        <div>
          <p class="lbg-kicker" style="color: #d9e8c5;">About the school</p>
          <h2 id="about-title">Free to learn. Open to every age.</h2>
          <p>
            LBGA is part of the Lettuce Beet Grapefruit family and is built by
            Absolutely Plausible Solutions. Content is shared for educational,
            non-commercial use under CC BY-NC-SA 4.0.
          </p>
        </div>
        <a class="button button--ghost" href="https://lettucebeetgrapefruit.com/">
          Meet the whole family
        </a>
      </div>
    </section>
  </main>

  <LbgFooter surface="academy" />
</body>
</html>
