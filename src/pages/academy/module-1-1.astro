---
// Module 1.1 · The Hidden History of Your Trash — implementation of
// "Module 1.1.dc.html" (Claude Design project "Interactive School Modules").
import LbgaModule from '../../layouts/LbgaModule.astro';
import LbgaFieldBrief from '../../components/LbgaFieldBrief.astro';
import QuizLbga from '../../components/QuizLbga.svelte';

const timeline = [
  {
    year: '3000<br>B.C.', tone: 'green',
    title: 'The primitive pit',
    body: 'In ancient Knossos, Crete, people dug deep pits, dumped refuse, and threw dirt over it when full. For millennia, that was the whole plan — let nature absorb our scraps.',
  },
  {
    year: 'PRE<br>1930s', tone: 'hazard',
    title: 'The chaos of the open dump',
    body: 'Industrial cities swelled and pits failed. Open dumps and round-the-clock incinerators became public-health disasters — millions of rats and flies spreading typhoid and cholera, toxic smoke, and chemical runoff into drinking-water wells.',
  },
  {
    year: '1935', tone: 'green-deep',
    title: 'The Fresno breakthrough',
    body: 'Engineer <strong>Jean Vincenz</strong> invented the "sanitary landfill" trench method: tractors compress trash into thin layers, and every single day workers seal it under clean dirt — starving pests of oxygen and food. It became the global blueprint.',
  },
  {
    year: '1976', tone: 'teal',
    title: 'The environmental shield',
    body: 'As petroleum plastics leaked permanent toxins into the earth, the U.S. <strong>RCRA Act</strong> outlawed open dumps. Modern landfills became engineered capsules — thick HDPE liners and clay to trap leachate, wells to pump it out, and vacuum networks to capture explosive methane.',
  },
];
---

<LbgaModule
  title="Module 1.1 · The Hidden History of Your Trash"
  description="You drop something in the bin and it's gone — but where? From the pits of ancient Knossos to the engineered capsules of the RCRA era, understand the invisible world under your feet. Track 1: Citizen Science & Action."
  trackLabel="Track 1: Citizen Science & Action"
  badgeLabel="Module 1.1 · Foundations"
  badgeDot="#6B9A3A"
  badgeColor="#CFE3B4"
  stripe="rgba(228,86,46,.07)"
  kicker="Module 1.1 · The Hidden History of Your Trash"
  kickerColor="#E9A98E"
  heading="The invisible world under your feet"
  lede="You drop something in the bin, close the lid, and walk away — and to your brain, it's gone. But the modern waste system is one of history's greatest invisible achievements. Understand how we got here, and you can change where the planet goes next."
  pills={[
    { text: '2 lessons' },
    { text: '2 knowledge checks' },
    { text: 'Field project', style: 'background:rgba(107,154,58,.22);border-color:rgba(107,154,58,.5);color:#CFE3B4' },
  ]}
  accent="#6B9A3A"
  storageKey="lbga_m1_1_done"
>
  <div class="lesson-kicker">Lesson 1</div>
  <h2 class="lesson-title">The timeline of the trash revolution</h2>
  <p class="lesson-intro">For thousands of years humans treated waste as an "out of sight, out of mind" problem. Four turning points changed that forever.</p>

  <div class="timeline">
    {timeline.map((t) => (
      <div class="tl-card">
        <div class={`tl-card__year tl-card__year--${t.tone}`} set:html={t.year} />
        <div>
          <div class="tl-card__title">{t.title}</div>
          <div class="tl-card__body" set:html={t.body} />
        </div>
      </div>
    ))}
  </div>

  <section aria-label="Knowledge check — history and engineering">
    <div class="lm-check-kicker">Knowledge check · History &amp; engineering</div>
    <div class="lm-quiz-frame">
      <QuizLbga client:visible quizId="academy_1_1_a" />
    </div>
  </section>

  <div class="lesson-kicker">Lesson 2</div>
  <h2 class="lesson-title">The tomb effect — and your power</h2>
  <p class="lesson-intro">The modern landfill is an engineering marvel with one massive design flaw: it is a <em>tomb</em>.</p>

  <div class="callout callout--teal">
    Because landfills are tightly compressed and starved of oxygen and moisture, things don't rot. A head of lettuce or a newspaper buried in 1980 can still be intact and readable today. Synthetic items — like petroleum plastic bags — stay for hundreds of years, locking away resources and slowly leaking microplastics.
  </div>
  <div class="callout callout--green">
    <strong>Your power.</strong> By sorting correctly and routing organics and certified-compostable materials to composting instead of the landfill, you keep the capsule clean and cut methane. You move our world from a dead-end "bury-and-forget" habit into a living, circular economy. That's the gratitude hierarchy in action.
  </div>

  <section aria-label="Knowledge check — impact and action">
    <div class="lm-check-kicker">Knowledge check · Impact &amp; action</div>
    <div class="lm-quiz-frame">
      <QuizLbga client:visible quizId="academy_1_1_b" />
    </div>
  </section>

  <LbgaFieldBrief
    kicker="Ongoing field project"
    kickerColor="#E9A98E"
    title="Landfill Detective"
    body="Find where your own trash actually goes. Look up your nearest landfill or transfer station, note when it opened, and list three materials it does <em>not</em> accept. Photograph your home bins and estimate what fraction could be composted or reused instead of buried."
    chips={['① Locate your landfill', '② List 3 rejected materials', '③ Audit your own bins']}
    chipColor="#CFE3B4"
    chipBg="rgba(107,154,58,.18)"
    chipBorder="rgba(107,154,58,.4)"
  />
</LbgaModule>

<style>
  .lesson-kicker {
    font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
    color: #57862F; font-weight: 700; margin-bottom: 8px;
  }
  .lesson-title { font-family: 'Newsreader', serif; font-size: 28px; font-weight: 500; margin: 0 0 8px; line-height: 1.12; }
  .lesson-intro { font-size: 15px; line-height: 1.65; color: #3d3a32; margin: 0 0 22px; max-width: 66ch; }

  .timeline { display: flex; flex-direction: column; gap: 12px; margin-bottom: 26px; }
  .tl-card {
    background: #FCFAF4; border: 1px solid #E4DDCC; border-radius: 16px;
    padding: 18px 20px; display: flex; gap: 16px; align-items: flex-start;
  }
  .tl-card__year {
    flex: 0 0 auto; font-family: 'Share Tech Mono', monospace; font-size: 12px; font-weight: 700;
    border-radius: 8px; padding: 6px 9px; text-align: center; line-height: 1.3; width: 66px;
  }
  .tl-card__year--green { color: #6B9A3A; background: #ECF1E0; }
  .tl-card__year--green-deep { color: #57862F; background: #ECF1E0; }
  .tl-card__year--hazard { color: #C0532A; background: #FBE7DE; }
  .tl-card__year--teal { color: #3E7E86; background: #E1EFF0; }
  .tl-card__title { font-family: 'Newsreader', serif; font-size: 18px; font-weight: 500; margin-bottom: 4px; }
  .tl-card__body { font-size: 13.5px; color: #5b5445; line-height: 1.55; }

  .callout {
    display: flex; gap: 16px; border-radius: 16px; padding: 18px 20px;
    font-size: 14px; line-height: 1.6;
  }
  .callout--teal {
    background: #F4EFE4; border: 1px solid #E4DDCC; border-left: 4px solid #3E7E86;
    color: #2b5257; margin-bottom: 16px;
  }
  .callout--green {
    background: #ECF1E0; border: 1px solid #CFE0B4; border-left: 4px solid #6B9A3A;
    color: #2f4d1c; margin-bottom: 28px;
  }
</style>
