// module in the Module 2.1 system. Content built from the fact-checked
// academy_2_6_a quiz: the single- vs multi-stream trade-off and
// container-deposit return rates.
import LbgaModule from '../../layouts/LbgaModule.astro';
import LbgaBriefing from '../../components/LbgaBriefing.astro';
import LbgaFieldBrief from '../../components/LbgaFieldBrief.astro';
import QuizLbga from '../../components/QuizLbga.svelte';

const briefings = [
  {
    title: 'Briefing 1 · Stream architecture',
    tag: 'the trade-off',
    body: `The first design decision is how many bins a citizen faces. <strong>Single-stream</strong> (everything in one bin) lifts participation because it asks almost nothing — and pays for it with higher contamination mixed into every commodity. <strong>Dual- and multi-stream</strong> systems keep bales cleaner but shift sorting effort onto residents. There is no free option, only a trade-off tuned to your MRF's capability and your buyers' specs.`,
    callout: `<strong>Design rule:</strong> choose the stream count your processing line and commodity buyers can actually absorb — not the one that looks best in a brochure.`,
  },
  {
    title: 'Briefing 2 · The financial nudge',
    tag: 'incentives',
    body: `Where behavior must change at scale, price beats persuasion. <strong>Container-deposit schemes (bottle bills)</strong> attach a small refundable value to each beverage container and routinely achieve <strong>80%+ return rates</strong> — clean, sorted material that never touches the curbside stream. <strong>Pay-as-you-throw</strong> pricing does the same upstream, charging households by the trash they generate rather than a flat fee.`,
    callout: `<strong>Operator's read:</strong> a refundable dime outperforms any sign ever printed. Design the incentive first, the poster second.`,
  },
  {
    title: 'Briefing 3 · Design the ideal path',
    tag: 'the details',
    body: `At the bin itself, the details do the sorting. <strong>Shaped apertures</strong> — a round hole for bottles and cans, a slot for paper — physically reject the wrong item. <strong>Consistent colors</strong> across the whole city build habit; <strong>photo-based signage</strong> of actual local items beats text and icons; and every recycling bin needs a <strong>paired trash bin</strong> beside it, or it becomes the trash bin.`,
    callout: `<strong>The one-second rule:</strong> every extra second of decision at the bin raises contamination. Good infrastructure design removes the decision entirely.`,
  },
];
---

