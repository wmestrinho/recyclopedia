---
// The DJ Pallet Table — the real-build companion to /diy/pallet-guide.
// A photographed build log: the guide's 9-step process run start-to-finish
// on a mobile DJ booth, built outdoors over nine sessions (Apr 15 – May 13).
// Same LBGA warm-theme document sheet as pallet-guide.astro.
const img = (name: string) => `/images/diy/${name}.jpeg`;

const log = [
  {
    date: 'Apr 15', step: 'Step 1 · Source', img: 'dj-01-sourcing',
    alt: 'Stacks of free reclaimed pallets in a parking lot at sunset',
    title: 'A truckload of free pallets',
    body: 'The build starts where the guide says it starts: collecting more pallets than the plan needs. Every one of these was headed for the dumpster. Stacked, inspected, and hauled with a waste margin — some of these boards will split, and that has to be fine.',
  },
  {
    date: 'Apr 16', step: 'Step 7 · Assemble', img: 'dj-02-caster-base',
    alt: 'A rectangular base frame on casters next to a stack of pallets',
    title: 'The base goes rolling first',
    body: 'A DJ booth lives on wheels — it has to roll out for a show and roll away after. So the very first assembly is a low rectangular base frame on casters. Everything else in this log gets built on top of it.',
  },
  {
    date: 'Apr 21', step: 'Steps 3–4 · Deconstruct & prep', img: 'dj-03-boards',
    alt: 'Pallet boards and frame parts laid out flat on artificial turf',
    title: 'Break down, lay out, sort',
    body: 'Pallets apart, nails out, and the reclaimed boards laid out across the flat frame to find their places. This is the unglamorous middle of every pallet build — and exactly the "hidden time sink" the guide warns about. The layout doubles as a live inventory: the design gets drawn around these boards, not an ideal cut list.',
  },
  {
    date: 'Apr 21', step: 'Step 7 · Assemble', img: 'dj-04-skeleton',
    alt: 'The booth frame standing upright for the first time',
    title: 'The skeleton stands',
    body: 'Same session: the first uprights go on and the frame stands at working height for the first time. From here the booth has its footprint — everything after this is skin and detail.',
  },
  {
    date: 'Apr 28', step: 'Step 7 · Assemble', img: 'dj-05-frame-square',
    alt: 'The frame up on folding work tables under a tent, being squared',
    title: 'Square it before you trust it',
    body: 'Up on the work tables to check the frame is square and the joints are solid. Screws and pilot holes throughout, per the guide — a booth that carries gear and drinks and elbows cannot wobble.',
  },
  {
    date: 'May 6', step: 'Step 7 · Assemble', img: 'dj-06-first-cladding',
    alt: 'The front face of the booth clad in pallet boards, mural behind',
    title: 'First skin',
    body: "Cladding starts on the crowd-facing side: pallet boards run horizontally across the frame, mixed widths and tones left as they came. This is the character new lumber can't fake — every board already had a life.",
  },
  {
    date: 'May 8', step: 'Step 7 · Assemble', img: 'dj-07-cubbies',
    alt: 'The working side of the booth showing open gear cubbies',
    title: 'Cubbies on the working side',
    body: 'The DJ side gets open cubbies — shelf bays framed into the carcass for cables, cases, and a drink that is not on the decks. The two faces of the booth do different jobs, and the frame reflects it.',
  },
  {
    date: 'May 8', step: 'Step 7 · Assemble', img: 'dj-08-clad-shell',
    alt: 'The booth closed in with cladding, drills resting on top',
    title: 'Closed in',
    body: 'By the end of the session the shell is closed. The drills live on top of the build between steps — the whole thing happens outdoors, in the yard of the venue where the booth will work.',
  },
  {
    date: 'May 11', step: 'Step 7 · Assemble', img: 'dj-09-top-frame',
    alt: 'The tabletop frame under construction with blocking visible',
    title: 'Framing the deck',
    body: 'The top is its own small build: a framed deck with blocking where the weight will sit. Getting this layer right decides whether the finished booth reads as furniture or as a pile of pallets.',
  },
  {
    date: 'May 13', step: 'Step 5 · Design & measure', img: 'dj-10-deck-layout',
    alt: 'Tape measure and pencil marks laid across the sanded deck boards',
    title: 'Layout, twice',
    body: 'Final session. Tape and pencil across the sanded deck to lay out the gear wells — measured twice, marked once, exactly the boring discipline the guide preaches. A cut in the finished top is the one mistake you cannot sand away.',
  },
  {
    date: 'May 13', step: 'Step 8 · Finish', img: 'dj-11-gear-wells',
    alt: 'The finished tabletop with two recessed gear wells',
    title: 'The gear wells',
    body: 'Two recessed wells drop the gear into the deck instead of perching it on top — screens at eye line, cables out of sight, nothing sliding off mid-set. The top is sanded through the grits to a uniform blond.',
  },
  {
    date: 'May 13', step: 'Step 9 · Install', img: 'dj-12-night-done',
    alt: 'The finished booth at night in the venue yard',
    title: 'Done, at dusk',
    body: 'Twenty-nine days after the first truckload: the booth stands finished in the yard it was built in, photographed the way the guide closes every project — done, in place, and about to be used.',
  },
];

const sessions = [
  'Apr 15 — source & haul', 'Apr 16 — caster base', 'Apr 21 — breakdown + skeleton',
  'Apr 28 — squaring', 'Apr 29 — legs & rails', 'May 06 — first cladding',
  'May 08 — cubbies, closed shell', 'May 11 — deck frame', 'May 13 — wells, sand, done',
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The DJ Pallet Table — a real pallet build, start to finish | Recyclopedia</title>
  <meta name="description" content="A mobile DJ booth built entirely from reclaimed pallets — the DIY Pallet Guide's 9-step process run on a real build, photographed across nine sessions. Zero-waste, 100% upcycled." />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E♻%3C/text%3E%3C/svg%3E" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
</head>
<body>

<main class="sheet">

  <!-- ============ COVER ============ -->
  <section class="cover">
    <div class="kicker-brand">Absolutely Plausible</div>
    <h1>The DJ Pallet Table</h1>
    <p class="lede">A mobile DJ booth built entirely from reclaimed pallets — the field guide's nine steps run on a real build, start to finish.</p>
    <div class="cover-tagline">Zero-waste · 100% upcycled · built where it plays</div>
    <img class="cover-photo" src={img('build-dj-pallet-table')} alt="The finished DJ Pallet Table — a mobile pallet booth on casters" />
    <div class="cover-pills">
      <span class="pill pill--green">9 sessions · 29 days</span>
      <span class="pill pill--rust">Every stage photographed</span>
      <span class="pill pill--amber">Rolls on casters</span>
    </div>
    <p class="cover-note">This is the worked example from the field guide — the method itself lives at <a href="/diy/pallet-guide"><strong>Build Real Things from Pallet Wood</strong></a>.</p>
  </section>

  <!-- ============ AT A GLANCE ============ -->
  <section>
    <div class="kicker">The build at a glance</div>
    <h2>One booth, nine sessions</h2>
    <p class="mb-md">Built outdoors in the yard of the venue it now works in, across nine after-hours sessions between April 15 and May 13. Material cost: mostly screws and casters — the wood was headed for a dumpster.</p>
    <div class="card-grid">
      <div class="card"><div class="card__title">What it is</div><div class="card__body">A rolling DJ booth: clad show face, open gear cubbies on the working side, two recessed wells in the deck.</div></div>
      <div class="card"><div class="card__title">Material</div><div class="card__body">Reclaimed pallet boards and stringers throughout, plus screws and a set of casters.</div></div>
      <div class="card"><div class="card__title">Timeline</div><div class="card__body">April 15 → May 13. Nine sessions — deconstruction and prep took as long as the guide says they do.</div></div>
      <div class="card"><div class="card__title">Method</div><div class="card__body">The 9-step process from the field guide, in order, with the boring parts left in.</div></div>
    </div>
  </section>

  <!-- ============ BUILD LOG ============ -->
  <section>
    <div class="kicker kicker--grapefruit">Build log</div>
    <h2 class="mb-xs">Start to finish</h2>
    <p class="mb-md">Twelve moments from the log, in order, tagged with the step of the process they belong to.</p>

    {log.map((e) => (
      <article class="log-entry">
        <div class="log-head">
          <span class="log-date">{e.date}</span>
          <span class="log-step">{e.step}</span>
        </div>
        <img src={img(e.img)} alt={e.alt} loading="lazy" />
        <div class="log-title">{e.title}</div>
        <p class="log-body">{e.body}</p>
      </article>
    ))}
  </section>

  <!-- ============ SESSION TIMELINE ============ -->
  <section>
    <div class="session-plan">
      <div class="session-plan__kicker">The honest timeline</div>
      <div class="session-plan__body">
        {sessions.map((s) => (<>{s}<br /></>))}
      </div>
    </div>
  </section>

  <!-- ============ LESSONS ============ -->
  <section>
    <div class="kicker">What the build taught</div>
    <h2 class="mb-xs">Three things the guide got right</h2>
    <aside class="tip tip--amber"><strong>It's a multi-session build.</strong> Twenty-nine days, nine sessions — and a good share of that was deconstruction and nail-pulling, not building. Plan for it and it stops being frustrating.</aside>
    <aside class="tip tip--teal"><strong>Design around the wood you have.</strong> The board layout on the turf came before the final design. Mixed widths and tones went in as they came — that's the look, not a compromise.</aside>
    <aside class="tip tip--plain"><strong>Think about how it moves before you build.</strong> The casters went on before anything stood on them. A booth this size that couldn't roll would never leave the yard.</aside>
  </section>

  <!-- ============ BACK TO THE GUIDE ============ -->
  <section>
    <div class="featured">
      <img src={img('cover-free-pallets')} alt="A wall of free reclaimed pallets" loading="lazy" />
      <div>
        <span class="featured__badge">The method</span>
        <div class="featured__title">Build Real Things from Pallet Wood</div>
        <div class="featured__body">The full field guide behind this build — sourcing, the safety decision flow, tools, wood prep, the 9-step process, and the quick-start checklist. Free at <a href="/diy/pallet-guide"><strong>recyclopedia.cc/diy/pallet-guide</strong></a>.</div>
      </div>
    </div>
  </section>

  <footer class="doc-footer">
    <span>ABSOLUTELY PLAUSIBLE · THE DJ PALLET TABLE</span>
    <span>diy.recyclopedia.cc · CC BY-NC 4.0</span>
  </footer>

</main>

<style>
  /* LBGA warm theme tokens (design_handoff_lbga_theme/theme-tokens.css) */
  :root {
    --surface: #FCFAF4;
    --surface-alt: #F4EFE4;
    --line: #E4DDCC;
    --text: #26241E;
    --body: #3d3a32;
    --soft: #544e42;
    --muted: #77705F;
    --accent: #6B9A3A;
    --accent-mid: #57862F;
    --beet: #8A2450;
    --grapefruit: #E4562E;
    --status-drop: #B07A1E;   --status-drop-bg: #F6ECD6;   --status-drop-line: #E8D5A8;
    --status-partial: #3E7E86; --status-partial-bg: #E1EFF0; --status-partial-line: #C4DEE1;
    --status-hazard: #C0532A;  --status-hazard-bg: #FBE7DE;
    --status-yes-bg: #ECF1E0;
    --font: 'Hanken Grotesk', system-ui, -apple-system, sans-serif;
    --font-display: 'Newsreader', Georgia, serif;
    --font-mono: 'Share Tech Mono', monospace;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body { background: #3a362d; font-family: var(--font); color: var(--text); -webkit-font-smoothing: antialiased; }

  .sheet {
    max-width: 820px;
    margin: 0 auto;
    background: var(--surface);
    padding: clamp(24px, 6vw, 68px);
  }
  @media (min-width: 900px) {
    .sheet { margin: 40px auto; border-radius: 6px; box-shadow: 0 20px 60px rgba(0,0,0,.35); }
  }

  section { margin-top: 38px; }
  section:first-child { margin-top: 0; }

  /* Type */
  h1 { font-family: var(--font-display); font-size: clamp(34px, 7vw, 52px); font-weight: 500; line-height: 1.02; letter-spacing: -.02em; margin: 0 0 14px; }
  h2 { font-family: var(--font-display); font-size: 26px; font-weight: 500; line-height: 1.15; margin: 0 0 12px; }
  p { font-size: 14px; line-height: 1.7; color: var(--body); margin: 0 0 12px; }
  .mb-md { margin-bottom: 16px; }
  .mb-xs { margin-bottom: 6px; }

  .kicker { font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: var(--accent); font-weight: 700; margin-bottom: 8px; }
  .kicker--grapefruit { color: var(--grapefruit); }

  /* Cover */
  .kicker-brand { font-family: var(--font-mono); font-size: 11px; letter-spacing: .34em; text-transform: uppercase; color: var(--status-hazard); margin-bottom: 16px; }
  .lede { font-size: 16px; line-height: 1.55; color: var(--soft); margin: 0 0 8px; max-width: 52ch; }
  .cover-tagline { font-family: var(--font-mono); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--accent); margin-bottom: 22px; }
  .cover-photo { width: 100%; height: 360px; object-fit: cover; object-position: center 40%; border-radius: 14px; display: block; margin-bottom: 20px; }
  .cover-pills { display: flex; gap: 10px; flex-wrap: wrap; }
  .pill { padding: 7px 14px; border-radius: 999px; font-size: 12px; font-weight: 600; }
  .pill--green { background: var(--status-yes-bg); color: #4E7A2E; }
  .pill--rust { background: var(--status-hazard-bg); color: var(--status-hazard); }
  .pill--amber { background: var(--status-drop-bg); color: var(--status-drop); }
  .cover-note { font-size: 12.5px; color: var(--muted); margin: 18px 0 0; }
  .cover-note a, .featured__body a { color: inherit; }
  .cover-note strong, .featured__body strong { color: var(--text); }

  /* Cards */
  .card-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .card { background: var(--surface-alt); border: 1px solid var(--line); border-radius: 12px; padding: 13px; break-inside: avoid; }
  .card__title { font-family: var(--font-display); font-size: 15px; font-weight: 500; margin-bottom: 4px; }
  .card__body { font-size: 12.5px; color: var(--muted); line-height: 1.5; }

  /* Build log */
  .log-entry { margin-top: 26px; break-inside: avoid; }
  .log-entry:first-of-type { margin-top: 0; }
  .log-head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 8px; }
  .log-date { font-family: var(--font-mono); font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--grapefruit); }
  .log-step { font-family: var(--font-mono); font-size: 11px; letter-spacing: .06em; color: var(--muted); }
  .log-entry img { width: 100%; height: 340px; object-fit: cover; border-radius: 12px; display: block; }
  .log-title { font-family: var(--font-display); font-size: 19px; font-weight: 500; margin: 10px 0 4px; }
  .log-body { font-size: 13.5px; line-height: 1.65; color: var(--body); margin: 0; }

  /* Session timeline (dark mono card) */
  .session-plan { background: var(--text); border-radius: 12px; padding: 16px 18px; break-inside: avoid; }
  .session-plan__kicker { font-family: var(--font-mono); font-size: 10px; letter-spacing: .14em; text-transform: uppercase; color: #E9A98E; margin-bottom: 8px; }
  .session-plan__body { font-size: 13px; line-height: 1.85; color: #EAE4D6; font-family: var(--font-mono); }

  /* Tips */
  .tip { display: block; border-radius: 12px; padding: 14px 16px; font-size: 13px; line-height: 1.55; break-inside: avoid; margin-top: 14px; }
  .tip--amber { background: var(--status-drop-bg); border: 1px solid var(--status-drop-line); border-left: 4px solid var(--status-drop); color: #6b511a; }
  .tip--teal { background: var(--status-partial-bg); border: 1px solid var(--status-partial-line); border-left: 4px solid var(--status-partial); color: #2b5257; }
  .tip--plain { background: var(--surface-alt); border: 1px solid var(--line); color: var(--soft); }

  /* Back-to-guide card */
  .featured { display: flex; gap: 14px; align-items: center; background: var(--surface-alt); border: 1px solid var(--line); border-radius: 14px; padding: 12px; break-inside: avoid; }
  .featured img { width: 150px; height: 110px; object-fit: cover; border-radius: 10px; flex: 0 0 auto; }
  .featured__badge { display: inline-block; padding: 3px 10px; border-radius: 999px; background: var(--grapefruit); color: #fff; font-size: 10px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; margin-bottom: 6px; }
  .featured__title { font-family: var(--font-display); font-size: 18px; font-weight: 500; margin-bottom: 3px; }
  .featured__body { font-size: 12.5px; color: var(--muted); line-height: 1.5; }

  /* Document footer */
  .doc-footer { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; font-family: var(--font-mono); font-size: 8.5px; letter-spacing: .06em; color: #9a927f; padding-top: 6px; border-top: 1px solid var(--line); margin-top: 44px; }

  /* Responsive */
  @media (max-width: 640px) {
    .card-grid { grid-template-columns: 1fr; }
    .cover-photo { height: 240px; }
    .log-entry img { height: 240px; }
    .featured { flex-direction: column; align-items: flex-start; }
    .featured img { width: 100%; height: 160px; }
  }

  /* Print — letter, 0.7in margins, matching the guide */
  @page { size: letter; margin: 0.7in; }
  @media print {
    body { background: #fff; }
    .sheet { max-width: none; margin: 0; padding: 0; box-shadow: none; border-radius: 0; }
    .cover-photo { height: 300px; }
    .log-entry img { height: 260px; }
    section { margin-top: 30px; }
    a { color: inherit; text-decoration: none; }
  }
</style>

</body>
</html>
