---
// DIY Pallet Guide — implementation of "DIY Pallet Guide.dc.html"
// (Claude Design project "Interactive School Modules", LBGA warm theme).
// Rendered as a standalone document page: warm sheet on a dark desk,
// print-friendly (letter, 0.7in margins).
const img = (name: string) => `/images/diy/${name}.jpeg`;

const steps = [
  { n: 1, title: 'Source', body: 'Collect pallets plus a waste margin — budget 30–40% extra.' },
  { n: 2, title: 'Inspect & Select', body: 'Every pallet passes the safety flow before it comes home.' },
  { n: 3, title: 'Deconstruct', body: 'Recip saw between boards and stringers to cut the nails.' },
  { n: 4, title: 'Prep Wood', body: 'Remove fasteners, sort, clean, sand (60→120→220).' },
  { n: 5, title: 'Design & Measure', body: 'Sketch around real board sizes. Measure twice, mark in pencil.' },
  { n: 6, title: 'Cut', body: 'Cut a little long if unsure — you can always trim, never un-trim.' },
  { n: 7, title: 'Assemble', body: 'Screws beat nails; pre-drill pilot holes. Frame first, keep it square.' },
  { n: 8, title: 'Finish', body: 'Seal for its environment: poly indoors, spar urethane out, food-safe for food.' },
  { n: 9, title: 'Install', body: 'Place it, then photograph it done and in use.' },
];

const showcase = [
  { src: 'build-shoe-rack-a', alt: 'Pallet shoe rack', title: 'Wall shoe rack', body: 'one pallet, mounted whole.' },
  { src: 'build-can-shelf', alt: 'Vertical can shelf', title: 'Vertical can shelf', body: 'half a pallet on end.' },
  { src: 'build-command-center', alt: 'Calendar command center', title: 'Command center', body: 'painted, magnet strip + board.' },
  { src: 'build-painted-pallet', alt: 'Sealed painted pallet', title: 'Sealed & painted', body: 'finishing, step 8.' },
  { src: 'build-shoe-rack-b', alt: 'Loaded entry rack', title: 'Entryway rack', body: 'loaded, with a book ledge.' },
  { src: 'build-stage-platform', alt: 'Pallet event stage decked with plywood', title: 'Event stage deck', body: 'decked over with plywood.' },
];

const stamps = [
  { code: 'HT', body: 'Heat Treated — heated to kill pests, no chemicals', badge: '✓ SAFE', tone: 'safe', rowTone: 'yes' },
  { code: 'KD', body: 'Kiln Dried — dried, not chemically treated', badge: '✓ SAFE', tone: 'safe', rowTone: '' },
  { code: 'DB', body: 'Debarked — bark removed (look for HT/KD too)', badge: '✓ OK', tone: 'ok', rowTone: '' },
  { code: 'MB', body: '<strong>Methyl Bromide</strong> — fumigated with a toxic pesticide', badge: '✕ NEVER', tone: 'never', rowTone: 'hazard' },
  { code: 'none', body: "Likely domestic-only — US doesn't require treatment for domestic use", badge: '⚠ INSPECT', tone: 'inspect', rowTone: '' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Build Real Things from Pallet Wood — DIY Pallet Guide | Recyclopedia</title>
  <meta name="description" content="A practical field guide to sourcing, prepping, and building furniture from reclaimed pallets. The 9-step process, safety decision flow, and quick start checklist. Zero-waste, 100% upcycled." />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E♻%3C/text%3E%3C/svg%3E" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
</head>
<body>

<main class="sheet">

  <!-- ============ COVER ============ -->
  <section class="cover">
    <div class="kicker-brand">Absolutely Plausible</div>
    <h1>Build Real Things<br />from Pallet Wood</h1>
    <p class="lede">A practical field guide to sourcing, prepping, and building furniture from reclaimed pallets.</p>
    <div class="cover-tagline">Zero-waste · 100% upcycled · no filler</div>
    <img class="cover-photo" src={img('cover-free-pallets')} alt="A wall of free reclaimed pallets" />
    <div class="cover-pills">
      <span class="pill pill--green">The 9-step process</span>
      <span class="pill pill--rust">Safety decision flow</span>
      <span class="pill pill--amber">Quick Start Checklist</span>
    </div>
    <p class="cover-note">See the whole process run on a real build — the DJ Pallet Table, documented free at <strong>diy.recyclopedia.cc/dj-pallet-table</strong>.</p>
  </section>

  <!-- ============ WHY / WHO ============ -->
  <section>
    <div class="kicker">Introduction</div>
    <h2>Why pallet wood</h2>
    <p>Pallets are everywhere. Most get used once and thrown away — millions of board-feet of usable softwood and hardwood, free for the asking. Turning that into furniture, fixtures, and builds is one of the cleanest forms of upcycling there is: the material already exists, the cost is mostly your time, and the result has a character new lumber can't fake.</p>
    <p class="mb-lg">But "free wood" comes with real things you have to know — some pallets are not safe to use, deconstruction is harder than it looks, and old wood needs proper prep. This guide covers all of it.</p>

    <h3>Who this is for</h3>
    <ul>
      <li>First-timers who want to build something from pallets and don't know where to start.</li>
      <li>DIYers who've tried it and hit problems — split boards, bent nails, wobbly results.</li>
      <li>Anyone who wants the safety knowledge before bringing reclaimed wood into their home.</li>
    </ul>
    <p class="aside">No prior woodworking experience assumed. If you can measure, cut, and drive a screw, you can do this.</p>
  </section>

  <!-- ============ THE ONE RULE ============ -->
  <aside class="rule-callout">
    <div class="rule-callout__mark">!</div>
    <div>
      <div class="rule-callout__kicker">The one rule that matters most</div>
      <div class="rule-callout__body"><strong>Never use a pallet stamped MB (Methyl Bromide)</strong> — it was fumigated with a toxic pesticide. Look for <strong>HT (Heat Treated)</strong> instead; that one's safe.</div>
    </div>
  </aside>

  <!-- ============ THE BASICS — SOURCING ============ -->
  <section>
    <div class="kicker">The Basics · 01</div>
    <h2>Sourcing — where to get pallets</h2>
    <p class="mb-md">Pallets are one of the few genuinely free building materials. Most businesses pay to have them hauled away, so a polite ask usually gets a yes.</p>
    <div class="two-col">
      <div>
        <div class="col-label col-label--green">Good places to ask</div>
        <ul class="tight">
          <li>Hardware stores, garden centers, nurseries</li>
          <li>Furniture and appliance stores</li>
          <li>Pet food / feed / farm-supply stores</li>
          <li>Liquor stores and beverage distributors</li>
          <li>Construction sites (ask the site manager first)</li>
          <li>Free listings on Marketplace / Craigslist</li>
        </ul>
      </div>
      <div>
        <div class="col-label col-label--beet">Rules of the road</div>
        <ul class="tight">
          <li><strong>Always ask.</strong> Don't take pallets off a property without permission — even if they look abandoned.</li>
          <li><strong>Ask for the manager.</strong> Front-line staff often can't say yes; managers usually can.</li>
          <li><strong>Take the good ones.</strong> Don't haul home cracked, soaked, or rotten pallets just because they're free.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ============ SAFETY ============ -->
  <section>
    <div class="kicker">The Basics · 02</div>
    <h2>Safety — which pallets are safe</h2>
    <p class="mb-md">The most important section in this guide. A small percentage of pallets are genuinely unsafe. Pallets used for international shipping carry an <strong>IPPC stamp</strong> — a stylized wheat-stalk logo next to a treatment code. The code is what matters.</p>

    <div class="stamp-table">
      {stamps.map((s) => (
        <div class={`stamp-row ${s.rowTone ? `stamp-row--${s.rowTone}` : ''}`}>
          <span class={`stamp-code ${s.code === 'MB' ? 'stamp-code--danger' : ''} ${s.code === 'none' ? 'stamp-code--muted' : ''}`}>{s.code}</span>
          <span class="stamp-desc" set:html={s.body} />
          <span class={`stamp-badge stamp-badge--${s.tone}`}>{s.badge}</span>
        </div>
      ))}
    </div>

    <div class="card-grid">
      <div class="card"><div class="card__title">Colored = rental property</div><div class="card__body">Blue (CHEP), red (PECO/LPR), brown (IPP) belong to rental pools. Taking them is theft — use plain whitewood.</div></div>
      <div class="card"><div class="card__title">Contamination</div><div class="card__body">Skip spills, oily stains, chemical odors, or unknown residue. Trust your nose and eyes.</div></div>
      <div class="card"><div class="card__title">Physical hazards</div><div class="card__body">Protruding nails, splinters, mold, rot. Wear gloves when handling.</div></div>
      <div class="card"><div class="card__title">Dust</div><div class="card__body">Reclaimed wood carries mold spores, dirt, droppings. Wear a dust mask when sanding or cutting.</div></div>
    </div>
  </section>

  <!-- ============ TOOLS ============ -->
  <section>
    <div class="kicker">The Basics · 03</div>
    <h2>Tools &amp; safety gear</h2>
    <p class="mb-md">You don't need a full workshop. This is the realistic minimum.</p>
    <div class="two-col mb-md">
      <div>
        <div class="col-label col-label--beet">Deconstruction</div>
        <ul class="tight">
          <li>Pry bar / wrecking bar — separating boards from stringers</li>
          <li>Reciprocating saw + metal-cutting blades — the fastest way to break pallets down</li>
          <li>Hammer — knocking joints apart, punching nails through</li>
          <li>Nail punch / pliers / cat's paw — removing old nails</li>
        </ul>
      </div>
      <div>
        <div class="col-label col-label--green">Building</div>
        <ul class="tight">
          <li>Circular saw or miter saw — cutting to length</li>
          <li>Drill / driver — pilot holes and screws</li>
          <li>Orbital sander + sandpaper (60/80/120/220)</li>
          <li>Tape measure, speed square, pencil, clamps</li>
        </ul>
      </div>
    </div>
    <aside class="tip tip--amber">
      <strong>Cut the nails, don't fight them.</strong> Levering nailed boards apart splits them. A recip saw slicing the nails saves the wood — and your patience. &nbsp;·&nbsp; <strong>Safety gear is not optional:</strong> work gloves, eye protection, dust mask (sanding), ear protection (power tools).
    </aside>
  </section>

  <!-- ============ WOOD PREP ============ -->
  <section>
    <div class="kicker">The Basics · 04</div>
    <h2>Wood prep</h2>
    <ol class="mb-md">
      <li><strong>Remove all fasteners.</strong> Pull or punch out every nail and staple — a single missed nail will ruin a saw blade or sander pad.</li>
      <li><strong>Sort the wood.</strong> Boards vary in thickness, width, and quality. Sort into good faces, structural pieces, and scrap.</li>
      <li><strong>Clean.</strong> Brush off dirt, wipe down, and let damp wood dry fully before building.</li>
      <li><strong>Sand in stages.</strong> Coarse first (60–80) to knock down roughness, then 120, then 220 for surfaces touched or seen.</li>
      <li><strong>Check for damage.</strong> Set aside cracked, split, rotted, or warped boards. Pallet wood is free — be picky.</li>
    </ol>
    <aside class="tip tip--teal">
      <strong>Measure your real inventory.</strong> New-lumber plans assume consistent dimensions; pallet wood doesn't have that. Design around the wood you actually have, not an ideal cut list.
    </aside>
  </section>

  <!-- ============ THE PROCESS ============ -->
  <section>
    <div class="kicker kicker--grapefruit">The Process</div>
    <h2 class="mb-xs">The 9-step process</h2>
    <p class="mb-md">Every pallet build — a shelf, a table, a planter, a bar — follows the same nine steps. Learn the process once; it works for any project.</p>
    <div class="card-grid">
      {steps.map((s) => (
        <div class="card step-card">
          <div class="step-card__head"><span class="step-card__num">{s.n}</span><span class="step-card__title">{s.title}</span></div>
          <div class="card__body">{s.body}</div>
        </div>
      ))}
    </div>
    <aside class="tip tip--plain">
      <strong>Time &amp; expectation.</strong> Deconstruction and prep are the hidden time sinks. A piece of furniture is realistically a multi-session build over days or weeks — not an afternoon. Plan for it.
    </aside>
  </section>

  <!-- ============ QUICK START CHECKLIST ============ -->
  <section>
    <div class="kicker kicker--grapefruit">Quick Start</div>
    <h2 class="mb-xs">Start a pallet project — checklist</h2>
    <p class="mb-md">Use this before your first cut. If you can check every box, you're ready to start.</p>
    <div class="two-col two-col--checklist">
      <div class="check-block"><div class="check-block__title">1 · Safety first (non-negotiable)</div><div class="check-block__items">☐ Reject any pallet stamped MB<br />☐ Only plain, discarded pallets<br />☐ Reject spills / stains / smells<br />☐ Gloves, eye protection, dust mask</div></div>
      <div class="check-block"><div class="check-block__title">2 · Sourcing plan</div><div class="check-block__items">☐ 2–3 sources to ask<br />☐ Ask permission before taking<br />☐ Collect 30–40% extra material</div></div>
      <div class="check-block"><div class="check-block__title">3 · Minimum tool kit</div><div class="check-block__items">☐ Pry bar &nbsp; ☐ Hammer &nbsp; ☐ Drill<br />☐ Saw (circular / miter / recip)<br />☐ Sander + 60/120/220<br />☐ Tape, square, pencil</div></div>
      <div class="check-block"><div class="check-block__title">4 · Ready to build</div><div class="check-block__items">☐ Boards clean and dry<br />☐ No nails or staples remain<br />☐ Sorted by thickness / quality<br />☐ Rough sketch of the build</div></div>
    </div>
    <div class="session-plan">
      <div class="session-plan__kicker">Your first 2-hour session</div>
      <div class="session-plan__body">0:00 — Inspect + reject unsafe / contaminated pallets<br />0:20 — Deconstruct one pallet fully<br />1:00 — Remove all nails / staples from usable boards<br />1:30 — Sort boards by size / quality + quick cleanup</div>
    </div>
  </section>

  <!-- ============ SHOWCASE ============ -->
  <section>
    <div class="kicker">Showcase</div>
    <h2 class="mb-xs">Real pallet builds</h2>
    <p class="mb-md">Everything below started as a discarded pallet — same nine steps, wildly different results.</p>
    <div class="showcase-grid">
      {showcase.map((f) => (
        <figure class="showcase-fig">
          <img src={img(f.src)} alt={f.alt} loading="lazy" />
          <figcaption><strong>{f.title}</strong> — {f.body}</figcaption>
        </figure>
      ))}
    </div>
    <div class="featured">
      <img src={img('build-dj-pallet-table')} alt="The DJ Pallet Table — a mobile pallet booth on casters" loading="lazy" />
      <div>
        <span class="featured__badge">Featured worked example</span>
        <div class="featured__title">The DJ Pallet Table</div>
        <div class="featured__body">A mobile DJ booth built entirely from reclaimed pallets — the whole nine-step process, start to finish. Documented free at <strong>diy.recyclopedia.cc/dj-pallet-table</strong>.</div>
      </div>
    </div>
  </section>

  <footer class="doc-footer">
    <span>ABSOLUTELY PLAUSIBLE · DIY PALLET GUIDE</span>
    <span>diy.recyclopedia.cc · CC BY-NC 4.0</span>
  </footer>

</main>

<style>
  /* LBGA warm theme tokens (design_handoff_lbga_theme/theme-tokens.css) */
  :root {
    --surface: #FCFAF4;
    --surface-alt: #F4EFE4;
    --line: #E4DDCC;
    --text: #26241E;
    --body: #3d3a32;
    --soft: #544e42;
    --muted: #77705F;
    --accent: #6B9A3A;
    --accent-mid: #57862F;
    --beet: #8A2450;
    --grapefruit: #E4562E;
    --status-drop: #B07A1E;   --status-drop-bg: #F6ECD6;   --status-drop-line: #E8D5A8;
    --status-partial: #3E7E86; --status-partial-bg: #E1EFF0; --status-partial-line: #C4DEE1;
    --status-hazard: #C0532A;  --status-hazard-bg: #FBE7DE;  --status-hazard-line: #E8C7B8;
    --status-no: #A33143;
    --status-yes-bg: #ECF1E0;
    --font: 'Hanken Grotesk', system-ui, -apple-system, sans-serif;
    --font-display: 'Newsreader', Georgia, serif;
    --font-mono: 'Share Tech Mono', monospace;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body { background: #3a362d; font-family: var(--font); color: var(--text); -webkit-font-smoothing: antialiased; }

  .sheet {
    max-width: 820px;
    margin: 0 auto;
    background: var(--surface);
    padding: clamp(24px, 6vw, 68px);
  }
  @media (min-width: 900px) {
    .sheet { margin: 40px auto; border-radius: 6px; box-shadow: 0 20px 60px rgba(0,0,0,.35); }
  }

  section { margin-top: 38px; }
  section:first-child { margin-top: 0; }

  /* Type */
  h1 { font-family: var(--font-display); font-size: clamp(34px, 7vw, 52px); font-weight: 500; line-height: 1.02; letter-spacing: -.02em; margin: 0 0 14px; }
  h2 { font-family: var(--font-display); font-size: 26px; font-weight: 500; line-height: 1.15; margin: 0 0 12px; }
  h3 { font-family: var(--font-display); font-size: 19px; font-weight: 500; margin: 0 0 10px; }
  p, ul, ol { font-size: 14px; line-height: 1.7; color: var(--body); margin: 0 0 12px; }
  ul, ol { padding-left: 20px; }
  .mb-lg { margin-bottom: 22px; }
  .mb-md { margin-bottom: 16px; }
  .mb-xs { margin-bottom: 6px; }
  .aside { font-size: 13.5px; line-height: 1.6; color: var(--muted); font-style: italic; margin: 0; }

  .kicker { font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: var(--accent); font-weight: 700; margin-bottom: 8px; }
  .kicker--grapefruit { color: var(--grapefruit); }

  /* Cover */
  .kicker-brand { font-family: var(--font-mono); font-size: 11px; letter-spacing: .34em; text-transform: uppercase; color: var(--status-hazard); margin-bottom: 16px; }
  .lede { font-size: 16px; line-height: 1.55; color: var(--soft); margin: 0 0 8px; max-width: 52ch; }
  .cover-tagline { font-family: var(--font-mono); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--accent); margin-bottom: 22px; }
  .cover-photo { width: 100%; height: 360px; object-fit: cover; border-radius: 14px; display: block; margin-bottom: 20px; }
  .cover-pills { display: flex; gap: 10px; flex-wrap: wrap; }
  .pill { padding: 7px 14px; border-radius: 999px; font-size: 12px; font-weight: 600; }
  .pill--green { background: var(--status-yes-bg); color: #4E7A2E; }
  .pill--rust { background: var(--status-hazard-bg); color: var(--status-hazard); }
  .pill--amber { background: var(--status-drop-bg); color: var(--status-drop); }
  .cover-note { font-size: 12.5px; color: var(--muted); margin: 18px 0 0; }
  .cover-note strong { color: var(--text); }

  /* One-rule callout */
  .rule-callout { display: flex; gap: 14px; background: var(--status-hazard-bg); border: 1px solid var(--status-hazard-line); border-left: 4px solid var(--status-hazard); border-radius: 14px; padding: 18px 20px; margin-top: 26px; break-inside: avoid; }
  .rule-callout__mark { flex: 0 0 auto; width: 36px; height: 36px; border-radius: 10px; background: var(--status-hazard); color: #fff; display: grid; place-items: center; font-family: var(--font-display); font-size: 20px; font-weight: 600; }
  .rule-callout__kicker { font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--status-hazard); font-weight: 700; margin-bottom: 4px; }
  .rule-callout__body { font-size: 14px; line-height: 1.55; color: #5c3324; }

  /* Two-column blocks */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 8px; }
  .col-label { font-size: 11px; letter-spacing: .1em; text-transform: uppercase; font-weight: 700; margin-bottom: 8px; }
  .col-label--green { color: var(--accent-mid); }
  .col-label--beet { color: var(--beet); }
  ul.tight { font-size: 13.5px; line-height: 1.65; margin: 0; padding-left: 18px; }

  /* Stamp table */
  .stamp-table { border: 1px solid var(--line); border-radius: 12px; overflow: hidden; margin-bottom: 22px; break-inside: avoid; }
  .stamp-row { display: grid; grid-template-columns: 56px 1fr auto; gap: 10px; align-items: center; padding: 11px 14px; border-bottom: 1px solid var(--line); }
  .stamp-row:last-child { border-bottom: none; }
  .stamp-row--yes { background: var(--status-yes-bg); }
  .stamp-row--hazard { background: var(--status-hazard-bg); }
  .stamp-row--hazard .stamp-desc { color: #5c3324; }
  .stamp-code { font-family: var(--font-mono); font-weight: 700; font-size: 14px; }
  .stamp-code--danger { color: var(--status-hazard); }
  .stamp-code--muted { font-size: 12px; color: var(--muted); }
  .stamp-desc { font-size: 13px; color: var(--body); }
  .stamp-badge { padding: 3px 10px; border-radius: 999px; color: #fff; font-size: 10.5px; font-weight: 700; white-space: nowrap; }
  .stamp-badge--safe { background: var(--accent-mid); }
  .stamp-badge--ok { background: var(--status-drop); }
  .stamp-badge--never { background: var(--status-no); }
  .stamp-badge--inspect { background: var(--status-partial); }

  /* Cards */
  .card-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .card { background: var(--surface-alt); border: 1px solid var(--line); border-radius: 12px; padding: 13px; break-inside: avoid; }
  .card__title { font-family: var(--font-display); font-size: 15px; font-weight: 500; margin-bottom: 4px; }
  .card__body { font-size: 12.5px; color: var(--muted); line-height: 1.5; }
  .step-card { padding: 14px; }
  .step-card__head { display: flex; align-items: center; gap: 8px; margin-bottom: 5px; }
  .step-card__num { font-family: var(--font-display); font-size: 20px; font-weight: 600; color: var(--accent); }
  .step-card__title { font-weight: 600; font-size: 14px; }

  /* Tips */
  .tip { display: block; border-radius: 12px; padding: 14px 16px; font-size: 13px; line-height: 1.55; break-inside: avoid; margin-top: 14px; }
  .tip--amber { background: var(--status-drop-bg); border: 1px solid var(--status-drop-line); border-left: 4px solid var(--status-drop); color: #6b511a; }
  .tip--teal { background: var(--status-partial-bg); border: 1px solid var(--status-partial-line); border-left: 4px solid var(--status-partial); color: #2b5257; }
  .tip--plain { background: var(--surface-alt); border: 1px solid var(--line); color: var(--soft); }

  /* Checklist */
  .two-col--checklist { gap: 14px; }
  .check-block { break-inside: avoid; }
  .check-block__title { font-size: 12.5px; font-weight: 700; margin-bottom: 8px; }
  .check-block__items { font-size: 13px; line-height: 1.9; color: var(--body); }
  .session-plan { background: var(--text); border-radius: 12px; padding: 16px 18px; margin-top: 16px; break-inside: avoid; }
  .session-plan__kicker { font-family: var(--font-mono); font-size: 10px; letter-spacing: .14em; text-transform: uppercase; color: #E9A98E; margin-bottom: 8px; }
  .session-plan__body { font-size: 13px; line-height: 1.85; color: #EAE4D6; font-family: var(--font-mono); }

  /* Showcase */
  .showcase-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 18px; }
  .showcase-fig { margin: 0; break-inside: avoid; }
  .showcase-fig img { width: 100%; height: 150px; object-fit: cover; border-radius: 10px; display: block; }
  .showcase-fig figcaption { font-size: 12px; color: var(--muted); margin-top: 6px; }
  .showcase-fig figcaption strong { color: var(--text); }
  .featured { display: flex; gap: 14px; align-items: center; background: var(--surface-alt); border: 1px solid var(--line); border-radius: 14px; padding: 12px; break-inside: avoid; }
  .featured img { width: 150px; height: 110px; object-fit: cover; object-position: center 40%; border-radius: 10px; flex: 0 0 auto; }
  .featured__badge { display: inline-block; padding: 3px 10px; border-radius: 999px; background: var(--grapefruit); color: #fff; font-size: 10px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; margin-bottom: 6px; }
  .featured__title { font-family: var(--font-display); font-size: 18px; font-weight: 500; margin-bottom: 3px; }
  .featured__body { font-size: 12.5px; color: var(--muted); line-height: 1.5; }
  .featured__body strong { color: var(--text); }

  /* Document footer */
  .doc-footer { display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap; font-family: var(--font-mono); font-size: 8.5px; letter-spacing: .06em; color: #9a927f; padding-top: 6px; border-top: 1px solid var(--line); margin-top: 44px; }

  /* Responsive */
  @media (max-width: 640px) {
    .two-col, .card-grid { grid-template-columns: 1fr; }
    .two-col--checklist { grid-template-columns: 1fr 1fr; }
    .showcase-grid { grid-template-columns: 1fr 1fr; }
    .cover-photo { height: 240px; }
    .featured { flex-direction: column; align-items: flex-start; }
    .featured img { width: 100%; height: 160px; }
  }
  @media (max-width: 440px) {
    .two-col--checklist, .showcase-grid { grid-template-columns: 1fr; }
  }

  /* Print — letter, 0.7in margins, matching the doc-page source */
  @page { size: letter; margin: 0.7in; }
  @media print {
    body { background: #fff; }
    .sheet { max-width: none; margin: 0; padding: 0; box-shadow: none; border-radius: 0; }
    .cover-photo { height: 300px; }
    section { margin-top: 30px; }
    a { color: inherit; text-decoration: none; }
  }
</style>

