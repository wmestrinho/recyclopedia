---
import LbgFooter from '../../components/LbgFooter.astro';
import LbgHeader from '../../components/LbgHeader.astro';

const eventSubject = encodeURIComponent('LBG community event proposal');
const eventBody = encodeURIComponent(
  'Hi LBG team,\n\nI would like to propose or help with a community event.\n\nEvent idea:\nLocation:\nPreferred timing:\nHow I can help:\n',
);
const donationSubject = encodeURIComponent('Electronics for an LBG repair workshop');
const donationBody = encodeURIComponent(
  'Hi LBG team,\n\nI have electronics that may be useful for a repair workshop.\n\nItem(s):\nCondition:\nQuantity:\nLocation / ZIP:\nAnything else we should know:\n',
);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lettuce Beet Grapefruit — Community, Workshops, and Learning</title>
  <meta
    name="description"
    content="Lettuce Beet Grapefruit brings people together through practical sustainability workshops, community technology events, open learning, and respectful reuse."
  />
  <link rel="canonical" href="https://lettucebeetgrapefruit.com/" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/lbg-theme.css" />
</head>
<body class="lbg-site lbg-community">
  <a class="skip-link" href="#lbg-top">Skip to content</a>
  <LbgHeader surface="community" />

  <main class="site-shell" id="lbg-top">
    <section class="lbg-hero" aria-labelledby="lbg-title">
      <div class="lbg-hero__copy">
        <p class="lbg-kicker">Lettuce Beet Grapefruit</p>
        <h1 id="lbg-title">Lettuce Beet Grapefruit.</h1>
        <p class="lede">
          A community home for learning, fixing, sharing, and keeping useful
          materials in motion. We bring people of every age together around
          practical technology and zero-waste action.
        </p>
        <div class="cta-row">
          <a class="button button--solid" href="#workshops">Explore workshops</a>
          <a class="button button--ghost" href="https://lettucebeetgrapefruit.org/">
            Enter LBG Academy
          </a>
        </div>
      </div>
      <aside class="lbg-hero__aside">
        <div class="lbg-wordmark" aria-label="Lettuce Beet Grapefruit">
          <span class="lbg-wordmark__line">
            <span class="lbg-wordmark__produce">Lettuce</span>
          </span>
          <span class="lbg-wordmark__line">
            <span class="lbg-wordmark__produce">Beet</span>
          </span>
          <span class="lbg-wordmark__line">
            <span class="lbg-wordmark__produce">Grapefruit</span>
          </span>
        </div>
        <p>Nothing wasted. Everything returned. Everyone welcome.</p>
      </aside>
    </section>

    <section class="lbg-section" id="workshops" aria-labelledby="workshops-title">
      <div class="lbg-section__heading">
        <p class="lbg-kicker">Workshops</p>
        <h2 id="workshops-title">Learn by opening things up.</h2>
        <p>
          Donated electronics become teaching material for practical, all-ages
          workshops focused on repair, responsible reuse, and understanding the
          technology already around us.
        </p>
      </div>
      <div class="lbg-card-grid">
        <article class="lbg-card">
          <span class="lbg-card__label">Build and fix</span>
          <h3>Repair Table</h3>
          <p>
            Bring a small device, learn safe diagnosis, and understand what can
            be repaired before anything is discarded.
          </p>
          <span class="lbg-card__footer">All ages · Guided practice</span>
        </article>
        <article class="lbg-card">
          <span class="lbg-card__label">Know the materials</span>
          <h3>Inside Electronics</h3>
          <p>
            Disassemble retired equipment safely and learn what its metals,
            plastics, boards, batteries, and components require.
          </p>
          <span class="lbg-card__footer">Hands-on · Material literacy</span>
        </article>
        <article class="lbg-card">
          <span class="lbg-card__label">Make another use</span>
          <h3>Second-Life Lab</h3>
          <p>
            Turn recovered parts into useful experiments, learning tools, and
            small projects instead of treating them as waste.
          </p>
          <span class="lbg-card__footer">Creative reuse · Open exploration</span>
        </article>
      </div>
    </section>

    <section class="lbg-section" id="events" aria-labelledby="events-title">
      <div class="lbg-section__heading">
        <p class="lbg-kicker">Community calendar</p>
        <h2 id="events-title">Meet locally. Share what works.</h2>
        <p>
          The public calendar will list technology meetups, repair workshops,
          sustainability gatherings, and local learning sessions.
        </p>
      </div>
      <div class="lbg-empty-state">
        <span class="lbg-status">Calendar opening</span>
        <h3 style="margin-top: 0.9rem;">The first dates are being assembled.</h3>
        <p>
          No fictional events and no stale listings. If you have a venue, a
          workshop idea, or want to help host the first local gathering, tell us.
        </p>
        <a
          class="button button--solid"
          href={`mailto:contact@absolutelyplausible.com?subject=${eventSubject}&body=${eventBody}`}
        >
          Propose an event
        </a>
      </div>
    </section>

    <section class="lbg-section" id="donate-tech" aria-labelledby="donate-title">
      <div class="lbg-band">
        <div>
          <p class="lbg-kicker" style="color: #d9e8c5;">Donate technology</p>
          <h2 id="donate-title">Give useful hardware a teaching life.</h2>
          <p>
            Workshop intake is being coordinated directly while the public
            calendar launches. Describe the item and its condition; we will reply
            before asking you to transport anything.
          </p>
        </div>
        <a
          class="button button--ghost"
          href={`mailto:contact@absolutelyplausible.com?subject=${donationSubject}&body=${donationBody}`}
        >
          Offer workshop hardware
        </a>
      </div>
    </section>

    <section class="lbg-section" id="family" aria-labelledby="family-title">
      <div class="lbg-section__heading">
        <p class="lbg-kicker">The family</p>
        <h2 id="family-title">Three doors into the same mission.</h2>
        <p>
          Use the engine when you need an answer, the Academy when you want the
          deeper why, and this community home when you are ready to learn together.
        </p>
      </div>
      <div class="lbg-card-grid">
        <article class="lbg-card">
          <span class="lbg-card__label">The action engine</span>
          <h3>Recyclopedia</h3>
          <p>Identify an item and find its highest respectful available path.</p>
          <a class="lbg-card__footer" href="https://recyclopedia.cc">
            Open recyclopedia.cc →
          </a>
        </article>
        <article class="lbg-card">
          <span class="lbg-card__label">The school</span>
          <h3>LBG Academy</h3>
          <p>Free courses, practical environmental learning, and Taste Tests.</p>
          <a class="lbg-card__footer" href="https://lettucebeetgrapefruit.org/">
            Enter the Academy →
          </a>
        </article>
        <article class="lbg-card">
          <span class="lbg-card__label">The builder</span>
          <h3>Absolutely Plausible</h3>
          <p>The zero-waste technology studio building and maintaining the family.</p>
          <a class="lbg-card__footer" href="https://absolutelyplausible.com">
            Meet AP →
          </a>
        </article>
      </div>
    </section>

    <section class="lbg-section" aria-labelledby="open-title">
      <div class="lbg-band">
        <div>
          <p class="lbg-kicker" style="color: #d9e8c5;">Built in the open</p>
          <h2 id="open-title">Public knowledge. In-house stewardship.</h2>
          <p>
            Code is open under AGPL-3.0. Educational content is shared under
            CC BY-NC-SA 4.0. Editing remains carefully reviewed in-house.
          </p>
        </div>
        <a class="button button--ghost" href="https://github.com/wmestrinho/recyclopedia">
          View the source
        </a>
      </div>
    </section>
  </main>

  <LbgFooter surface="community" />
</body>
</html>
